//MOVE     EXEC PGM=ADRDSSU,REGION=0M,PARM='TYPRUN=NORUN'                       
//FROMVOL  DD  UNIT=SYSDA,VOL=SER=A4USR1,DISP=SHR                               
//SYSPRINT DD SYSOUT=*                                                          
//SYSIN    DD *                                                                 
  COPY -                                                                        
  DATASET(INCLUDE(HARBORP.**, -                                                 
                  ZZCPM.**,   -                                                 
                  ZZDB.**))   -                                                 
  LOGINDD(FROMVOL)  -                                                           
  ALLD(*)     -                                                                 
  ALLEXCP     -                                                                 
  SELECTMULTI(ANY) -                                                            
  SPHERE      -                                                                 
  CATALOG     -                                                                 
  CANCELERROR -                                                                 
  DELETE      -                                                                 
  DYNALLOC    -                                                                 
  OPT(4) TOL(ENQF) -                                                            
  WAIT(10,10) -                                                                 
  ADMINISTRATOR                                                                 
/* 
//*-----------------------------------------------------------------*           
//* End of Job                                                                  
//*-----------------------------------------------------------------*                                                                              
//                                                                              
  STORCLAS(STGMGMT) -                                                           
  OUTDYNAM((TMM201)) -                                                          
