//VERIFY  EXEC PGM=ADRDSSU,COND=(5,LT),REGION=4096K                     00130000
//SYSPRINT DD  SYSOUT=*                                                 00140000
//DUMMY    DD  DUMMY                                                    00150000
//TAPE     DD  DSN=*.BACKUP.OUTDD,DISP=(OLD,KEEP),UNIT=TAPE             00160000
//SYSIN    DD  *                                                        00170000
 COPYDUMP INDD(TAPE) OUTDD(DUMMY)                                       00180000
