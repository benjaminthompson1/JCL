 DUMP FULL OPT(4) -                                                     00040000
      ALLD(*) ALLX -                                                    00050000
      INDD(INDD) -                                                      00060000
      OUTDD(OUTDD) -                                                    00070000
      CONCURRENT                                                        00071000
/*                                                                      00080000
