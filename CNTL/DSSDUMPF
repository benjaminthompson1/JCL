//*-- 1: FULL VOLUME BACKUP USING ADRDSSU -----------------------------*        
//BACKUP   EXEC PGM=ADRDSSU PARM='TYPRUN=NORUN'                         00012100
//SYSPRINT DD SYSOUT=*                                                  00012200
//INDD     DD VOL=SER=DRPAK1,UNIT=SYSDA,DISP=OLD                        00012300
//OUTDD    DD DSN=XBT.DRPAK1.MAINT.BACKUP,DISP=(,CATLG),                00018000
//         DCB=TRTCH=COMP,                                              00019000
//         UNIT=TAPE,RETPD=30                                           00020000
